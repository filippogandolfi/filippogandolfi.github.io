---
import Base from '../layouts/Base.astro';
import { profile, experiences, projectGroups, education, extras } from '../data/cv';
import { sitePath } from '../lib/paths';
---

<Base title="ctrlFG — Filippo Gandolfi · Test & Delivery Manager">
  <section class="hero">
    <p class="kicker mono">CIAO, I'M</p>
    <h1 transition:name="site-title">{profile.name}</h1>
    <p class="role">
      {profile.role} <span class="amp">&</span> {profile.subtitle}
    </p>
    <ul class="facts mono">
      <li>🌱 {profile.location}</li>
      <li><a href={`mailto:${profile.emails[0]}`} data-sound="tick">{profile.emails[0]}</a></li>
      <li><a href={profile.linkedin} data-sound="tick">LinkedIn</a></li>
      <li>🧤 goalkeeper</li>
    </ul>
    <div class="intro">
      {profile.intro.split('\n\n').map((p) => <p>{p}</p>)}
    </div>
  </section>

  <nav class="toc" aria-label="Sections">
    <a href="#work" data-sound="tick"><span class="sprig-mark" aria-hidden="true"></span>Work experience</a>
    <a href="#projects" data-sound="tick"><span class="sprig-mark" aria-hidden="true"></span>Projects</a>
    <a href="#education" data-sound="tick"><span class="sprig-mark" aria-hidden="true"></span>Education</a>
    <a href="#more" data-sound="tick"><span class="sprig-mark" aria-hidden="true"></span>Everything else</a>
  </nav>

  <section aria-labelledby="work">
    <h2 id="work"><span class="sprig-mark" aria-hidden="true"></span>Work experience</h2>
    {
      experiences.map((exp) => (
        <article class="entry">
          <div class="when mono">
            {exp.period}
            <span class="kind">{exp.kind}</span>
          </div>
          <div class="what">
            <h3>{exp.title} · <span class="org">{exp.org}</span></h3>
            <p>{exp.body}</p>
            <p class="tags">
              {exp.tags.map((t) => (
                <span class="pill">{t}</span>
              ))}
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <section aria-labelledby="projects">
    <h2 id="projects"><span class="sprig-mark" aria-hidden="true"></span>Projects</h2>
    {
      projectGroups.map((group) => (
        <div class="group">
          <h3 class="group-head">
            {group.heading} <span class="mono when-inline">{group.period}</span>
          </h3>
          {group.items.map((item) => (
            <article class="panel project">
              <strong>{item.name}</strong>
              <p>{item.body}</p>
              <p class="tags">
                {item.tags.map((t) => (
                  <span class="pill">{t}</span>
                ))}
              </p>
            </article>
          ))}
        </div>
      ))
    }
  </section>

  <section aria-labelledby="education">
    <h2 id="education"><span class="sprig-mark" aria-hidden="true"></span>Education</h2>
    {
      education.map((ed) => (
        <article class="entry">
          <div class="when mono">
            {ed.period}
            {ed.note && <span class="kind">{ed.note}</span>}
          </div>
          <div class="what">
            <h3>{ed.title} · <span class="org">{ed.org}</span></h3>
            <p>{ed.body}</p>
          </div>
        </article>
      ))
    }
  </section>

  <section aria-labelledby="more" class="more">
    <h2 id="more"><span class="sprig-mark" aria-hidden="true"></span>Everything else</h2>
    <div class="more-grid">
      <div class="panel">
        <h3>Languages</h3>
        <ul>
          {extras.languages.map((l) => (
            <li>
              {l.lang} — <span class="mono">{l.level}</span>
            </li>
          ))}
        </ul>
      </div>
      {
        extras.cards.map((card) =>
          card.href ? (
            <a href={sitePath(card.href)} class="panel card-link" data-sound="tick">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              <span class="read-more mono">{card.linkLabel ?? 'read more'} →</span>
            </a>
          ) : (
            <div class="panel">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </div>
          )
        )
      }
    </div>
  </section>
</Base>

<script>
  // Re-trigger the "arrival" animation on every anchor click.
  // Delegated on document so it survives Astro view-transition swaps.
  if (!(window as any).__anchorGlow) {
    (window as any).__anchorGlow = true;
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[href^="#"]');
      if (!link) return;
      const target = document.querySelector<HTMLElement>(link.getAttribute('href')!);
      if (!target) return;
      target.classList.remove('anchored');
      void target.offsetWidth; // restart the CSS animation
      target.classList.add('anchored');
      target.addEventListener('animationend', () => target.classList.remove('anchored'), { once: true });
    });
  }
</script>

<style>
  .hero { padding-top: 2.5rem; }

  .toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.6rem;
    margin: 2.2rem 0 0.5rem;
  }
  .toc a {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--moss);
    transition: transform 120ms ease, color 120ms ease;
  }
  .toc a:hover {
    color: var(--leaf);
    transform: translateY(-1px);
  }
  .toc .sprig-mark { transform: rotate(-4deg) scale(0.9); }

  section[aria-labelledby] h2 { scroll-margin-top: 1.5rem; }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes arrive-glow {
      0%   { background-size: 0% 100%; }
      25%  { background-size: 100% 100%; }
      70%  { background-size: 100% 100%; }
      100% { background-size: 0% 100%; }
    }
    @keyframes arrive-wiggle {
      0%, 100% { transform: rotate(-4deg) scale(1); }
      30%      { transform: rotate(8deg) scale(1.35); }
      60%      { transform: rotate(-10deg) scale(1.15); }
    }
    h2:target,
    h2.anchored {
      background-image: linear-gradient(var(--fern-soft), var(--fern-soft));
      background-repeat: no-repeat;
      background-position: left center;
      background-size: 0% 100%;
      animation: arrive-glow 1.4s ease-out 0.25s;
      border-radius: 6px;
    }
    h2:target .sprig-mark,
    h2.anchored .sprig-mark {
      animation: arrive-wiggle 0.7s ease-in-out 0.45s;
    }
  }
  .kicker {
    color: var(--leaf);
    letter-spacing: 0.25em;
    font-size: 0.8rem;
    margin: 0;
  }
  .role {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--ink-soft);
    margin: 0 0 1rem;
  }
  .amp { color: var(--leaf); }
  .facts {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    padding: 0;
    font-size: 0.8rem;
  }
  .intro p { max-width: 62ch; }

  .entry {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }
  .when {
    font-size: 0.78rem;
    color: var(--fern-deep);
    padding-top: 0.35rem;
  }
  .kind {
    display: block;
    color: var(--ink-soft);
    font-size: 0.72rem;
  }
  .what h3 { margin-top: 0; }
  .org { color: var(--moss); font-weight: 400; }
  .tags { margin: 0.4rem 0 0; }

  .group { margin-bottom: 2rem; }
  .group-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .when-inline { font-size: 0.75rem; color: var(--ink-soft); font-weight: 400; }
  .project { margin-bottom: 0.8rem; }
  .project p { margin: 0.3rem 0 0; font-size: 0.95rem; }

  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.8rem;
  }
  .more-grid h3 { margin-top: 0; }
  .more-grid ul { padding-left: 1.1rem; margin: 0; }
  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 2px solid transparent;
    transition: transform 140ms ease, border-color 140ms ease;
  }
  .card-link:hover {
    color: inherit;
    border-color: var(--fern);
    transform: rotate(-0.6deg) translateY(-2px);
  }
  .card-link p { flex: 1; }
  .read-more {
    font-size: 0.75rem;
    color: var(--leaf);
    margin-top: 0.5rem;
  }
  .card-link:hover .read-more { text-decoration: underline; }

  @media (max-width: 560px) {
    .entry { grid-template-columns: 1fr; gap: 0.2rem; }
    .when { padding-top: 0; }
    .kind { display: inline; margin-left: 0.6em; }
  }
</style>
