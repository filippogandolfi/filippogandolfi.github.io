---
import Base from '../layouts/Base.astro';
import { profile, experiences, projectGroups, education, extras } from '../data/cv';
---

<Base title="ctrlFG — Filippo Gandolfi · Test & Delivery Manager">
  <section class="hero">
    <p class="kicker mono">CIAO, I'M</p>
    <h1 transition:name="site-title">{profile.name}</h1>
    <p class="role">
      {profile.role} <span class="amp">&</span> {profile.subtitle}
    </p>
    <ul class="facts mono">
      <li>🌱 {profile.location}</li>
      <li><a href={`mailto:${profile.emails[0]}`} data-sound="tick">{profile.emails[0]}</a></li>
      <li><a href={profile.linkedin} data-sound="tick">LinkedIn</a></li>
      <li>🧤 goalkeeper</li>
    </ul>
    <div class="intro">
      {profile.intro.split('\n\n').map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section aria-labelledby="work">
    <h2 id="work"><span class="sprig-mark" aria-hidden="true"></span>Work experience</h2>
    {
      experiences.map((exp) => (
        <article class="entry">
          <div class="when mono">
            {exp.period}
            <span class="kind">{exp.kind}</span>
          </div>
          <div class="what">
            <h3>{exp.title} · <span class="org">{exp.org}</span></h3>
            <p>{exp.body}</p>
            <p class="tags">
              {exp.tags.map((t) => (
                <span class="pill">{t}</span>
              ))}
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <section aria-labelledby="projects">
    <h2 id="projects"><span class="sprig-mark" aria-hidden="true"></span>Projects</h2>
    {
      projectGroups.map((group) => (
        <div class="group">
          <h3 class="group-head">
            {group.heading} <span class="mono when-inline">{group.period}</span>
          </h3>
          {group.items.map((item) => (
            <article class="panel project">
              <strong>{item.name}</strong>
              <p>{item.body}</p>
              <p class="tags">
                {item.tags.map((t) => (
                  <span class="pill">{t}</span>
                ))}
              </p>
            </article>
          ))}
        </div>
      ))
    }
  </section>

  <section aria-labelledby="education">
    <h2 id="education"><span class="sprig-mark" aria-hidden="true"></span>Education</h2>
    {
      education.map((ed) => (
        <article class="entry">
          <div class="when mono">
            {ed.period}
            {ed.note && <span class="kind">{ed.note}</span>}
          </div>
          <div class="what">
            <h3>{ed.title} · <span class="org">{ed.org}</span></h3>
            <p>{ed.body}</p>
          </div>
        </article>
      ))
    }
  </section>

  <section aria-labelledby="more" class="more">
    <h2 id="more"><span class="sprig-mark" aria-hidden="true"></span>Everything else</h2>
    <div class="more-grid">
      <div class="panel">
        <h3>Languages</h3>
        <ul>
          {extras.languages.map((l) => (
            <li>
              {l.lang} — <span class="mono">{l.level}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="panel">
        <h3>On stage</h3>
        <p>{extras.other}</p>
      </div>
      <div class="panel">
        <h3>Between the posts</h3>
        <p>{extras.hobbies}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: 2.5rem; }
  .kicker {
    color: var(--leaf);
    letter-spacing: 0.25em;
    font-size: 0.8rem;
    margin: 0;
  }
  .role {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--ink-soft);
    margin: 0 0 1rem;
  }
  .amp { color: var(--leaf); }
  .facts {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    padding: 0;
    font-size: 0.8rem;
  }
  .intro p { max-width: 62ch; }

  .entry {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }
  .when {
    font-size: 0.78rem;
    color: var(--fern-deep);
    padding-top: 0.35rem;
  }
  .kind {
    display: block;
    color: var(--ink-soft);
    font-size: 0.72rem;
  }
  .what h3 { margin-top: 0; }
  .org { color: var(--moss); font-weight: 400; }
  .tags { margin: 0.4rem 0 0; }

  .group { margin-bottom: 2rem; }
  .group-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .when-inline { font-size: 0.75rem; color: var(--ink-soft); font-weight: 400; }
  .project { margin-bottom: 0.8rem; }
  .project p { margin: 0.3rem 0 0; font-size: 0.95rem; }

  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.8rem;
  }
  .more-grid h3 { margin-top: 0; }
  .more-grid ul { padding-left: 1.1rem; margin: 0; }

  @media (max-width: 560px) {
    .entry { grid-template-columns: 1fr; gap: 0.2rem; }
    .when { padding-top: 0; }
    .kind { display: inline; margin-left: 0.6em; }
  }
</style>
